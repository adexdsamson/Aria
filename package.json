{
  "name": "aria",
  "version": "0.1.0",
  "private": true,
  "description": "Aria — local-first desktop AI personal assistant for executives.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test:unit": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "postinstall": "node scripts/postinstall.mjs",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3-multiple-ciphers"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0",
    "@electron-toolkit/preload": "^3.0.0",
    "@scure/bip39": "^2.2.0",
    "ai": "^6.0.0",
    "better-sqlite3-multiple-ciphers": "^12.0.0",
    "google-auth-library": "^9.15.1",
    "googleapis": "^144.0.0",
    "node-cron": "^4.0.0",
    "ollama-ai-provider-v2": "^3.0.0",
    "p-queue": "^9.0.0",
    "pino": "^10.0.0",
    "pino-roll": "^4.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "@electron/rebuild": "^4.0.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "electron": "41.6.1",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "jsdom": "^25.0.0",
    "patch-package": "^8.0.0",
    "playwright": "^1.60.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.0"
  }
}
