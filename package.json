{
  "name": "aria",
  "version": "0.1.0",
  "private": true,
  "description": "Aria — local-first desktop AI personal assistant for executives.",
  "license": "MIT",
  "author": "adexdsamson <adexdsamson@gmail.com>",
  "homepage": "https://github.com/adexdsamson/Aria#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adexdsamson/Aria.git"
  },
  "bugs": {
    "url": "https://github.com/adexdsamson/Aria/issues"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "grep:insight-prose-no-raw": "node scripts/grep-insight-prose-no-raw.mjs",
    "verify:audit-view": "node scripts/verify-audit-view.mjs",
    "grep:no-network-from-signals": "node scripts/grep-no-network-from-signals.mjs",
    "grep:migration-callsite": "node scripts/grep-migration-callsite.mjs",
    "grep:no-fixture-leak": "node scripts/grep-no-fixture-leak.mjs",
    "lint:guard": "node scripts/grep-insight-prose-no-raw.mjs && node scripts/verify-audit-view.mjs && node scripts/grep-no-network-from-signals.mjs && node scripts/grep-migration-callsite.mjs && node scripts/grep-no-fixture-leak.mjs",
    "test:unit": "npm run lint:guard && vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "postinstall": "node scripts/postinstall.mjs",
    "rebuild:native": "node scripts/build-native-dual.mjs",
    "rebuild:native:electron": "electron-rebuild -f -w better-sqlite3-multiple-ciphers",
    "rebuild:native:node": "node scripts/build-native-dual.mjs --node-only",
    "release": "electron-builder --publish github",
    "release:mac": "electron-builder --mac --publish github",
    "release:win": "electron-builder --win --publish github",
    "icons:tray": "node scripts/build-tray-icons.mjs",
    "icons:app": "node scripts/build-app-icons.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0",
    "@azure/msal-node": "^3.8.10",
    "@electron-toolkit/preload": "^3.0.0",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/playfair-display": "^5.2.8",
    "@fontsource/source-sans-3": "^5.2.9",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@react-pdf/renderer": "^4.5.1",
    "@scure/bip39": "^2.2.0",
    "@tiptap/core": "^3.23.5",
    "@tiptap/react": "^3.23.5",
    "@tiptap/starter-kit": "^3.23.5",
    "ai": "^6.0.0",
    "better-sqlite3-multiple-ciphers": "^12.0.0",
    "chokidar": "^4.0.0",
    "cmdk": "^1.1.1",
    "docx": "^9.6.1",
    "electron-updater": "^6.8.3",
    "email-reply-parser": "^2.3.5",
    "exceljs": "^4.4.0",
    "google-auth-library": "^9.15.1",
    "googleapis": "^144.0.0",
    "isomorphic-fetch": "^3.0.0",
    "kokoro-js": "^1.2.1",
    "jose": "^6.2.3",
    "mammoth": "^1.12.0",
    "node-cron": "^4.0.0",
    "node-downloader-helper": "^2.1.11",
    "ollama-ai-provider-v2": "^3.0.0",
    "p-queue": "^9.0.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.7.284",
    "pino": "^10.0.0",
    "pino-roll": "^4.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.0.0",
    "rrule": "^2.8.1",
    "rss-parser": "^3.13.0",
    "sqlite-vec": "0.1.9",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "@electron/rebuild": "^4.0.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/microsoft-graph": "^2.40.1",
    "@types/node": "^20.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "electron": "41.6.1",
    "electron-builder": "^26.0.0",
    "electron-icon-builder": "^2.0.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^25.0.0",
    "patch-package": "^8.0.0",
    "playwright": "^1.60.0",
    "postcss": "^8.4.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "to-ico": "^1.1.5",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.0"
  },
  "build": {
    "appId": "com.aria.desktop",
    "productName": "Aria",
    "asarUnpack": [
      "**/node_modules/sqlite-vec/dist/native/**",
      "**/node_modules/sqlite-vec-darwin-x64/**",
      "**/node_modules/sqlite-vec-darwin-arm64/**",
      "**/node_modules/sqlite-vec-linux-x64/**",
      "**/node_modules/sqlite-vec-windows-x64/**",
      "**/node_modules/better-sqlite3-multiple-ciphers/**"
    ],
    "publish": {
      "provider": "github"
    },
    "mac": {
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "binaries": ["Contents/Resources/whisper-cli"],
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "protocols": [
      {
        "name": "Aria",
        "schemes": [
          "aria"
        ]
      }
    ],
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/",
        "to": ".",
        "filter": [
          "icon.ico",
          "icon.png",
          "tray-icon*.ico",
          "tray-iconTemplate*.png",
          "tray-iconBadgedTemplate*.png"
        ]
      },
      {
        "from": "build/whisper/windows/",
        "to": ".",
        "filter": ["whisper-cli.exe", "ggml.dll", "ggml-base.dll", "ggml-cpu.dll"],
        "platform": "win32"
      },
      {
        "from": "build/whisper/macos/",
        "to": ".",
        "filter": ["whisper-cli"],
        "platform": "darwin"
      }
    ]
  }
}
