{
  "name": "aria-landing-video",
  "version": "1.0.0",
  "description": "Remotion video for Aria landing page — UI walkthrough",
  "private": true,
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render AriaDemo out/aria-demo.mp4 --codec=h264",
    "render": "remotion render AriaDemo out/aria-demo.mp4 --codec=h264 && cp out/aria-demo.mp4 ../landing/assets/aria-demo.mp4",
    "preview": "remotion render AriaDemo out/aria-demo-preview.mp4 --codec=h264 --scale=0.5"
  },
  "dependencies": {
    "@remotion/cli": "4.0.290",
    "remotion": "4.0.290",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "typescript": "5.5.4"
  },
  "remotion": {
    "entryPoint": "src/index.tsx",
    "fps": 30,
    "durationInFrames": 900,
    "width": 1920,
    "height": 1080
  }
}
