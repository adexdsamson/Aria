# Plan 08-04 Task 6 — example env vars for release pipeline + dev.
#
# Copy this file to `.env.local` (gitignored by default — see .gitignore)
# and fill in real values for local dev / packaging. Production builds
# inject these via the shell environment in the CI pipeline; never
# commit real values.

# ---------------------------------------------------------------------------
# GitHub Releases — electron-builder publish target.
# ---------------------------------------------------------------------------
# Personal access token (PAT classic, `repo` scope) used by electron-builder
# during `pnpm run release` to publish artifacts. Documented in
# docs/RELEASE-RUNBOOK.md §8.
GH_TOKEN=

# ---------------------------------------------------------------------------
# Apple notarization — macOS staged signing (XCUT-05).
# ---------------------------------------------------------------------------
# Apple ID email used for the Developer Program enrollment.
APPLE_ID=
# App-specific password generated at https://appleid.apple.com.
# NEVER your account password.
APPLE_APP_SPECIFIC_PASSWORD=
# Team ID from https://developer.apple.com/account → Membership.
APPLE_TEAM_ID=

# ---------------------------------------------------------------------------
# Auto-updater channel selector.
# ---------------------------------------------------------------------------
# 'tester' tracks pre-release builds (default). 'latest' tracks GA.
ARIA_UPDATE_CHANNEL=tester

# ---------------------------------------------------------------------------
# OAuth client credentials (dev only — production builds inject via the
# packaging step's `define` plugin).
# ---------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_TENANT=common
